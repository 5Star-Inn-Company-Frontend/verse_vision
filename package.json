{
  "name": "versevision",
  "description": "VerseVision is a tool for Bible study and teaching.",
  "keywords": [
    "bible",
    "study",
    "teaching"
  ],
  "author": "Samji Diamond",
  "license": "MIT",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "main": "electron/main.cjs",
  "scripts": {
    "client:dev": "vite",
    "build": "vite build",
    "build:server": "tsc -p api/tsconfig.json",
    "app:build": "npm run build && npm run build:server",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "server:dev": "nodemon",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "electron:dev": "npm run app:build && electron .",
    "electron:win": "npm run app:build && electron-builder --win",
    "electron:mac": "npm run app:build && electron-builder --mac",
    "electron:linux": "npm run app:build && electron-builder --linux"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.21.2",
    "lucide-react": "^0.511.0",
    "multer": "^2.0.2",
    "openai": "^6.9.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0",
    "sql.js": "^1.13.0",
    "tailwind-merge": "^3.0.2",
    "ws": "^8.18.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vercel/node": "^5.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "concurrently": "^9.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "build": {
    "appId": "com.versevision.app",
    "productName": "VerseVision",
    "publish": "always",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "api/dist/**",
      "electron/**",
      "python/**",
      "data/**",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "python/**",
      "data/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "publisherName": "Samji Diamond"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.education",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": {
      "target": "AppImage",
      "category": "Education"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "VerseVision"
    }
  }
}
